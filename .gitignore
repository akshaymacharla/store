# Gitignore for the full monorepo

# ── Environment Variables ─────────────
.env
.env.local
.env.production

# ── Java / Maven ──────────────────────
target/
*.class
*.jar
*.war
*.ear
hs_err_pid*

# ── Node / npm ────────────────────────
node_modules/
dist/
.vite/
*.log
npm-debug.log*

# ── IDE ───────────────────────────────
.idea/
*.iml
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── OS ────────────────────────────────
.DS_Store
Thumbs.db
